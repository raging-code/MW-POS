<?xml version="1.0" encoding="utf-8"?>
<!--
  Replaces the default teal grid vector with a plain white background.
  White matches the MWlogo.png border so the adaptive icon looks clean
  on any Android launcher (circle, squircle, square, teardrop shapes).

  File location: android/app/src/main/res/drawable/ic_launcher_background.xml
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFFFF" />
</shape>